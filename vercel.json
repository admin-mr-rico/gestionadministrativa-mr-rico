{
  "buildCommand": "echo 'No build required'",
  "installCommand": "echo 'No installation needed'",
  "outputDirectory": "src",
  "public": "src",
  "routes": [
    { "src": "/css/(.*)",    "dest": "/css/$1" },
    { "src": "/js/(.*)",     "dest": "/js/$1" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/(.*)",        "dest": "/index.html" }
  ]
}
